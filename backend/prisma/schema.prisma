generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  createdAt DateTime   @default(now())
  password  String
  updatedAt DateTime
  Document  Document[]
}

model Document {
  id        String   @id @default(uuid())
  userId    String?
  fileName  String
  fileUrl   String
  status    String
  createdAt DateTime @default(now())
  User      User?    @relation(fields: [userId], references: [id])
}
